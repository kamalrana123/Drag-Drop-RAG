# ── Application ───────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite+aiosqlite:///./rag_builder.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_builder

# ── Redis + Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── File Storage ──────────────────────────────────────────────────────────────
# Options: local | s3 | azure
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# AWS S3 (when STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=your_key_id
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1

# Azure Blob (when STORAGE_BACKEND=azure)
# AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# AZURE_CONTAINER=rag-uploads

# ── Vector Databases ──────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
CHROMA_PERSIST_DIR=./chroma_db

# ── API Key Encryption ────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
